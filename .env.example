# Copy to .env (or .env.local) and fill in real values.

# Base URL of the Sierra Estates Realty backend (Next.js). No trailing slash.
# Local dev: http://localhost:3000   Production: https://sierra-estates.net
VITE_API_BASE_URL=http://localhost:3000

# Firebase project "sierra-blu" web config (Firebase Console -> Project settings -> General).
# Web API keys are not secret by design, but never hardcode them in source.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=sierra-blu.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=sierra-blu
VITE_FIREBASE_STORAGE_BUCKET=sierra-blu.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Agency WhatsApp number for the client-side "Chat on WhatsApp" CTA, in
# international format without "+" (e.g. 201234567890), used in wa.me links.
VITE_WHATSAPP_NUMBER=
